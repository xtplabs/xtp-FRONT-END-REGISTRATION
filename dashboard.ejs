<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>XTP Registration Dashboard</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }
        
        body {
            background: #f4f7fc;
            min-height: 100vh;
            padding: 30px;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .dashboard {
            width: 100%;
            max-width: 900px;
            background: white;
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, .1);
        }
        
        .header {
            text-align: center;
            margin-bottom: 25px;
        }
        
        .header h1 {
            color: #16a34a;
            margin-bottom: 10px;
        }
        
        .header p {
            color: #555;
        }
        
        .reg-id {
            background: #111827;
            color: white;
            padding: 18px;
            border-radius: 12px;
            text-align: center;
            font-size: 24px;
            font-weight: bold;
            margin-bottom: 25px;
        }
        
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
        }
        
        .card {
            background: #f8fafc;
            padding: 15px;
            border-radius: 12px;
        }
        
        .card h4 {
            color: #666;
            margin-bottom: 8px;
        }
        
        .card p {
            color: #111;
            font-weight: bold;
        }
        
        .notice {
            margin-top: 25px;
            background: #fff3cd;
            color: #856404;
            border-left: 5px solid #ffc107;
            padding: 18px;
            border-radius: 10px;
            line-height: 1.7;
        }
        
        .discount {
            margin-top: 25px;
            background: #d1fae5;
            color: #065f46;
            padding: 20px;
            border-radius: 12px;
            border-left: 5px solid #10b981;
        }
        
        .regular {
            margin-top: 25px;
            background: #fee2e2;
            color: #991b1b;
            padding: 20px;
            border-radius: 12px;
            border-left: 5px solid #ef4444;
        }
        
        .training {
            margin-top: 25px;
            background: #f8fafc;
            padding: 20px;
            border-radius: 12px;
        }
        
        .training h3 {
            margin-bottom: 10px;
            color: #16a34a;
        }
        
        .training ul {
            padding-left: 20px;
        }
        
        .training li {
            margin-bottom: 8px;
        }
        
        .footer {
            margin-top: 25px;
            text-align: center;
            color: #666;
        }
        
        @media(max-width:600px) {
            .reg-id {
                font-size: 18px;
            }
        }
    </style>
</head>

<body>

    <div class="dashboard">

        <div class="header">
            <h1>XTP FRONTEND DEVELOPMENT TRAINING</h1>
            <p>Registration Successful</p>
        </div>

        <div class="reg-id">
            REGISTRATION ID:
            <%= registrationId %>
        </div>

        <div class="grid">

            <div class="card">
                <h4>Full Name</h4>
                <p>
                    <%= user.name %>
                </p>
            </div>

            <div class="card">
                <h4>Phone Number</h4>
                <p>
                    <%= user.phone %>
                </p>
            </div>

            <div class="card">
                <h4>Email Address</h4>
                <p>
                    <%= user.gmail || "Not Provided" %>
                </p>
            </div>

            <div class="card">
                <h4>Gender</h4>
                <p>
                    <%= user.gender %>
                </p>
            </div>

            <div class="card">
                <h4>Training Date</h4>
                <p>27th June 2026</p>
            </div>

            <div class="card">
                <h4>Training Time</h4>
                <p>10:00 AM - 1:00 PM</p>
            </div>

            <div class="card">
                <h4>Duration</h4>
                <p>4 Weeks</p>
            </div>

            <div class="card">
                <h4>Location</h4>
                <p>Uwani, Enugu State</p>
            </div>

        </div>

        <div class="notice">
            <strong>IMPORTANT NOTICE:</strong><br> Payment is NOT required online.<br> Kindly make payment when you arrive at the training venue.<br><br> Venue Address:<br> No. 20 Isuochi Street, Uwani, Enugu State.<br><br> Please come with your Registration
            ID:
            <strong><%= registrationId %></strong>
        </div>

        <% if(discountEligible){ %>

            <div class="discount">
                <h3>🎉 Congratulations!</h3>
                <p>
                    You are among the first 10 registered participants and qualify for the discounted training fee.
                </p>
                <br>
                <h2>Training Fee: ₦5,000</h2>
                <br>
                <p>
                    Present your Registration ID when you arrive to claim your discount.
                </p>
            </div>

            <% } else { %>

                <div class="regular">
                    <h3>Discount Slots Filled</h3>
                    <p>
                        The first 10 discounted slots have been exhausted.
                    </p>
                    <br>
                    <h2>Training Fee: ₦10,000</h2>
                </div>

                <% } %>

                    <div class="training">
                        <h3>What You Will Learn</h3>

                        <ul>
                            <li>HTML Fundamentals</li>
                            <li>CSS Styling Techniques</li>
                            <li>Responsive Web Design</li>
                            <li>JavaScript Basics</li>
                            <li>Building Real Projects</li>
                            <li>Frontend Development Best Practices</li>
                        </ul>
                    </div>

                    <div class="footer">
                        <h3>XTP CONCEPT</h3>
                        <p>Learn Today • Build Tomorrow • Lead The Future</p>
                    </div>

    </div>

</body>

</html>